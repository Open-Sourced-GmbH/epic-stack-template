// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  username String  @unique
  name     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Account-deactivation marker (ADR-069). Null = active; a timestamp records
  // when an admin deactivated the account. This slice only reads it (the status
  // column shows Active for everyone); the deactivation write-path and the
  // deactivated-sign-in block arrive in a later slice.
  deactivatedAt DateTime?

  // Product-email opt-in. Consulted at the send site via the userPreferences
  // check-point helper; defaults on so existing accounts stay subscribed.
  allowProductEmails Boolean @default(true)

  image       UserImage?
  password    Password?
  posts       Post[]
  roles       Role[]
  sessions    Session[]
  connections Connection[]
  passkey     Passkey[]

  // Audit events this user *performed* (the actor side). FK is SetNull on delete
  // so deleting the user blanks the link but the row's denormalized actorLabel
  // keeps the trail readable (ADR-070). There is no target back-relation: an
  // audit target may be a Role/Session set, not just a User, so it is an
  // un-constrained id+type+label rather than an FK.
  auditEvents AuditEvent[]
}

model Post {
  id      String  @id @default(cuid())
  title   String
  slug    String  @unique
  body    String
  excerpt String?

  // Publication state: null = Draft, set = Published (the publication instant).
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Author *credit*, not ownership: deleting the author blanks the credit
  // (SetNull) but the Post — canonical content — stands. (Contrast the retired
  // Note, which cascade-deleted with its owner.)
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  authorId String?

  images PostImage[] @relation("PostImages")

  // The cover image is the one PostImage singled out by coverImageId; the rest
  // stay available for body images later.
  coverImage   PostImage? @relation("PostCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  coverImageId String?    @unique

  // Canonical, shared taxonomy (Post↔Tag is many-to-many).
  tags Tag[]

  // non-unique foreign key
  @@index([authorId])
  // the public feed orders by recency of publication
  @@index([publishedAt])
}

model PostImage {
  id        String  @id @default(cuid())
  altText   String?
  objectKey String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   Post   @relation("PostImages", fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  postId String

  // Back-reference for the cover relation: a PostImage may be some Post's cover.
  coverOf Post? @relation("PostCoverImage")

  // non-unique foreign key
  @@index([postId])
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts Post[]
}

model UserImage {
  id        String  @id @default(cuid())
  altText   String?
  objectKey String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId String @unique
}

model Password {
  hash String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId String @unique
}

model Session {
  id             String   @id @default(cuid())
  expirationDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId String

  // non-unique foreign key
  @@index([userId])
}

model Permission {
  id          String @id @default(cuid())
  action      String // e.g. create, read, update, delete
  entity      String // e.g. post, user, etc.
  access      String // e.g. own or any
  description String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles Role[]

  @@unique([action, entity, access])
}

model Role {
  id          String @id @default(cuid())
  name        String @unique
  description String @default("")

  // Whether this is a built-in (bootstrap-seeded) role — `user`/`admin` (ADR-069).
  // System roles are protected: they cannot be renamed or deleted through the UI,
  // and the seed reconciles this flag but never overwrites their (now DB-owned)
  // permission grants. Custom roles (created through the UI) default to false.
  system Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  permissions Permission[]
}

model Verification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  /// The type of verification, e.g. "email" or "phone"
  type String

  /// The thing we're trying to verify, e.g. a user's email or phone number
  target String

  /// The secret key used to generate the otp
  secret String

  /// The algorithm used to generate the otp
  algorithm String

  /// The number of digits in the otp
  digits Int

  /// The number of seconds the otp is valid for
  period Int

  /// The valid characters for the otp
  charSet String

  /// When it's safe to delete this verification
  expiresAt DateTime?

  @@unique([target, type])
}

// An append-only record of a sensitive role/user change (ADR-070). Each row
// snapshots the actor's and target's identity *labels* alongside the optional
// keys, so the trail stays readable after the actor or target is deleted — the
// moment an audit log matters most. Never updated or deleted through the UI.
model AuditEvent {
  id String @id @default(cuid())

  // Typed event name, e.g. "role.granted", "user.deactivated". The vocabulary
  // lives in audit.server.ts (`AuditEventName`); stored as text to stay forward
  // compatible with new event kinds without a migration.
  event String

  // Actor (who did it): optional FK + a denormalized identity label captured at
  // write time. SetNull keeps the row when the actor is later deleted.
  actor      User?   @relation(fields: [actorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  actorId    String?
  actorLabel String?

  // Target (what it was done to): an un-constrained id + type discriminator plus
  // a denormalized label. No FK — a target may be a Role, a Session set, or a
  // User, so it is not modelled as a single relation.
  targetId    String?
  targetType  String?
  targetLabel String?

  // Structured context as serialized JSON (SQLite has no Json column in this
  // schema — cf. Verification/Passkey). Read back via audit.server.ts.
  details String?

  createdAt DateTime @default(now())

  // non-unique foreign key
  @@index([actorId])
  // the viewer filters by target and event, and orders by recency
  @@index([targetId])
  @@index([event])
  @@index([createdAt])
}

model Connection {
  id           String @id @default(cuid())
  providerName String
  providerId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId String

  @@unique([providerName, providerId])
}

model Passkey {
  id             String   @id
  aaguid         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  publicKey      Bytes
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  webauthnUserId String
  counter        BigInt
  deviceType     String // 'singleDevice' or 'multiDevice'
  backedUp       Boolean
  transports     String? // Stored as comma-separated values

  @@index(userId)
}
