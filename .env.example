DATABASE_PATH="./prisma/data.db"
DATABASE_URL="file:./data.db?connection_limit=1"
CACHE_DATABASE_PATH="./other/cache.db"
# Directory LiteFS mounts in production; locally any path works (litefs-js v2
# requires this to be set). Matches litefs-js v1's old default.
LITEFS_DIR="/litefs"
SESSION_SECRET="super-duper-s3cret"
HONEYPOT_SECRET="super-duper-s3cret"
RESEND_API_KEY="re_blAh_blaHBlaHblahBLAhBlAh"
SENTRY_DSN="your-dsn"

# this is set to a random value in the Dockerfile
INTERNAL_COMMAND_TOKEN="some-made-up-token"

# the mocks and some code rely on these two being prefixed with "MOCK_"
# if they aren't then the real github api will be attempted
GITHUB_CLIENT_ID="MOCK_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="MOCK_GITHUB_CLIENT_SECRET"
GITHUB_TOKEN="MOCK_GITHUB_TOKEN"
GITHUB_REDIRECT_URI="https://example.com/auth/github/callback"

# set this to false to prevent search engines from indexing the website
# default to allow indexing for seo safety
ALLOW_INDEXING="true"

# Matomo analytics (self-hosted, cookieless). Set both to mount the tracker;
# leave unset to disable analytics. The tracker URL is also added to the CSP.
# MATOMO_URL="https://matomo.example.com"
# MATOMO_SITE_ID="1"

# Cloudflare Turnstile bot challenge on signup. Set both to enable the widget
# and server-side verification; leave unset to disable. Site key is public,
# secret key is not. Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SITE_KEY="0x4AAA..."
# TURNSTILE_SECRET_KEY="0x4AAA..."

# Tigris Object Storage (S3-compatible) Configuration
AWS_ACCESS_KEY_ID="mock-access-key"
AWS_SECRET_ACCESS_KEY="mock-secret-key"
AWS_REGION="auto"
AWS_ENDPOINT_URL_S3="https://fly.storage.tigris.dev"
BUCKET_NAME="mock-bucket"
